{
  "name": "stt-codex-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compare-transcript": "tsx src/app/cli/compare-transcript.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" vitest.config.ts eslint.config.mjs --no-error-on-unmatched-pattern",
    "format": "prettier --write package.json tsconfig.json vitest.config.ts eslint.config.mjs \"docs/**/*.md\" \"src/**/*.ts\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern package.json tsconfig.json vitest.config.ts eslint.config.mjs \"docs/**/*.md\" \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
