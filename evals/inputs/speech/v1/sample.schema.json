{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yonghyeun/stt-codex-cli/evals/inputs/speech/v1/sample.schema.json",
  "title": "Speech Input v1 Sample Metadata",
  "type": "object",
  "required": [
    "sample_id",
    "prompt_id",
    "category",
    "recording_status",
    "expected_text_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "sample_id": {
      "type": "string",
      "pattern": "^cmd-[0-9]{4}$"
    },
    "prompt_id": {
      "type": "string",
      "pattern": "^P[0-9]{2}$"
    },
    "category": {
      "enum": [
        "korean_command",
        "code_switch",
        "file_path",
        "cli_option",
        "code_identifier",
        "long_form"
      ]
    },
    "recording_status": {
      "enum": ["recorded"]
    },
    "expected_text_policy": {
      "enum": [
        "codex_final_input",
        "actual_spoken_phrase",
        "korean_phonetic_transcript"
      ]
    },
    "rerecord_reason": {
      "type": "string",
      "minLength": 1
    },
    "contract_alignment_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
